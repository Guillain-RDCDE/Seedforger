<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Seedforger.App.ViewModels"
        x:Class="Seedforger.App.Views.MainWindow"
        x:CompileBindings="False"
        Title="Seedforger" Width="900" Height="720"
        MinWidth="820" MinHeight="560"
        Background="#15161A" FontFamily="Segoe UI, Inter, sans-serif">

  <Window.Resources>
    <SolidColorBrush x:Key="Bg" Color="#15161A" />
    <SolidColorBrush x:Key="Card" Color="#1E2025" />
    <SolidColorBrush x:Key="CardHi" Color="#24262C" />
    <SolidColorBrush x:Key="Stroke" Color="#2C2F36" />
    <SolidColorBrush x:Key="Text" Color="#ECEEF2" />
    <SolidColorBrush x:Key="Muted" Color="#8A909C" />
    <SolidColorBrush x:Key="Accent" Color="#4C8DF6" />
    <SolidColorBrush x:Key="Green" Color="#22C55E" />
    <SolidColorBrush x:Key="Red" Color="#F05050" />
    <SolidColorBrush x:Key="Input" Color="#16171B" />
    <SolidColorBrush x:Key="LogBg" Color="#0F1013" />
    <SolidColorBrush x:Key="LogText" Color="#86E0A8" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource Card}" />
      <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="14,12" />
    </Style>
    <Style Selector="TextBlock.section">
      <Setter Property="Foreground" Value="{StaticResource Muted}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="{StaticResource Muted}" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <!-- nav buttons -->
    <Style Selector="Button.nav">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource Muted}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource CardHi}" />
      <Setter Property="TextBlock.Foreground" Value="{StaticResource Text}" />
    </Style>
    <!-- pill buttons -->
    <Style Selector="Button.pill">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBox.field">
      <Setter Property="Background" Value="{StaticResource Input}" />
      <Setter Property="Foreground" Value="{StaticResource Text}" />
      <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="{StaticResource Input}" />
      <Setter Property="Foreground" Value="{StaticResource Text}" />
      <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="MinHeight" Value="34" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="56,*,Auto,Auto" Margin="20,10,20,14">

    <!-- ===== header ===== -->
    <Grid Grid.Row="0">
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="Seedforger" Foreground="{StaticResource Text}" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Text="{Binding L[subtitle]}" Foreground="{StaticResource Muted}" FontSize="11" Margin="1,2,0,0" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="2">
        <Button Classes="nav" Content="{Binding L[nav.guided]}" Click="OnGuided" />
        <Button Classes="nav" Content="{Binding L[nav.campaigns]}" Click="OnCampaigns" />
        <Button Classes="nav" Content="{Binding L[nav.tools]}" Click="OnTools" />
        <Button Classes="nav" Content="⚙" Click="OnSettings" />
        <Button Classes="nav" Content="?" Click="OnHelp" />
      </StackPanel>
    </Grid>

    <!-- ===== content ===== -->
    <Grid Grid.Row="1" ColumnDefinitions="*,16,300" Margin="0,6,0,6">

      <!-- left config column -->
      <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="10">

        <Border Classes="card">
          <StackPanel Spacing="12">
            <TextBlock Classes="section" Text="{Binding L[card.torrent]}" />
            <Grid ColumnDefinitions="*,10,110">
              <TextBox Grid.Column="0" Classes="field" IsReadOnly="True" Text="{Binding TorrentDisplay}" />
              <Button Grid.Column="2" Classes="pill" Background="{StaticResource Accent}"
                      Content="{Binding L[browse]}" Click="OnBrowse" Height="36" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Classes="section" Text="{Binding L[card.client]}" />
            <Grid ColumnDefinitions="*,10,150,10,110">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Classes="label" Text="{Binding L[client]}" />
                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Families}" SelectedItem="{Binding SelectedFamily}" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Classes="label" Text="{Binding L[version]}" />
                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Versions}" SelectedItem="{Binding SelectedVersion}" />
              </StackPanel>
              <Button Grid.Column="4" Classes="pill" Background="{StaticResource CardHi}" Foreground="{StaticResource Text}"
                      Content="{Binding L[advanced]}" Click="OnAdvanced" VerticalAlignment="Bottom" Height="34" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="card">
          <StackPanel Spacing="8">
            <TextBlock Classes="section" Text="{Binding L[card.speed]}" />
            <Grid ColumnDefinitions="160,16,*">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Classes="label" Text="{Binding L[upload_kbs]}" />
                <TextBox Classes="field" Text="{Binding UploadText}" />
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Classes="label" Text="{Binding L[mode]}" />
                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Modes}" SelectedIndex="{Binding SelectedModeIndex}" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

      </StackPanel>
      </ScrollViewer>

      <!-- right LIVE column -->
      <Border Grid.Column="2" Classes="card" VerticalAlignment="Stretch">
        <StackPanel Spacing="4">
          <TextBlock Classes="section" Text="{Binding L[live]}" />
          <TextBlock Text="{Binding RatioText}" Foreground="{StaticResource Text}" FontSize="44" FontWeight="Bold" Margin="0,10,0,0" />
          <TextBlock Classes="section" Text="{Binding L[ratio]}" />
          <StackPanel Margin="0,22,0,0" Spacing="2">
            <TextBlock Classes="section" Text="{Binding L[uploaded]}" />
            <TextBlock Text="{Binding UploadedText}" Foreground="{StaticResource Text}" FontSize="15" FontWeight="SemiBold" />
          </StackPanel>
          <StackPanel Margin="0,16,0,0" Spacing="2">
            <TextBlock Classes="section" Text="{Binding L[swarm]}" />
            <TextBlock Text="{Binding SwarmText}" Foreground="{StaticResource Text}" FontSize="15" FontWeight="SemiBold" />
          </StackPanel>
          <StackPanel Margin="0,16,0,0" Spacing="2">
            <TextBlock Classes="section" Text="{Binding L[status]}" />
            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontSize="15" FontWeight="SemiBold" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    <!-- ===== start / stop (pinned, under the left column) ===== -->
    <Grid Grid.Row="2" ColumnDefinitions="*,16,300" Margin="0,10,0,10">
      <Grid Grid.Column="0" ColumnDefinitions="*,12,150">
        <Button Grid.Column="0" Classes="pill" Background="{StaticResource Green}" Height="46" FontSize="15"
                Content="{Binding L[start_seeding]}" Command="{Binding StartCommand}" IsEnabled="{Binding NotRunning}" />
        <Button Grid.Column="2" Classes="pill" Background="{StaticResource Red}" Height="46" FontSize="15"
                Content="{Binding L[stop]}" Command="{Binding StopCommand}" IsEnabled="{Binding IsRunning}" />
      </Grid>
    </Grid>

    <!-- ===== activity log ===== -->
    <StackPanel Grid.Row="3" Spacing="6">
      <TextBlock Classes="section" Text="{Binding L[activity]}" />
      <Border Background="{StaticResource LogBg}" CornerRadius="10" Padding="12,10" Height="104">
        <ScrollViewer Name="LogScroller" VerticalScrollBarVisibility="Auto">
          <TextBlock Text="{Binding ActivityText}" Foreground="{StaticResource LogText}"
                     FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" TextWrapping="Wrap" />
        </ScrollViewer>
      </Border>
    </StackPanel>
  </Grid>
</Window>
